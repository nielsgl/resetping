{
  "name": "resetping",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "mock:status": "node scripts/mock-status-server.mjs",
    "metrics:installs": "node scripts/snapshot-release-downloads.mjs",
    "hooks:install": "pre-commit install --install-hooks --hook-type pre-commit --hook-type pre-push",
    "hooks:run": "pre-commit run --all-files"
  },
  "dependencies": {
    "@sentry/browser": "^10.43.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
