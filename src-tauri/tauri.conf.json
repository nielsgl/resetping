{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResetPing",
  "version": "0.1.5",
  "identifier": "dev.nielsvangalen.resetping",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ResetPing Settings",
        "width": 920,
        "height": 760,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4MkY4MzQ0Q0MzODEzQkMKUldTOEV6ak1SSU12eUkvUzVRZ3BxN0RCT0YwTlF3RE9ZWmxyUHB1K0M2VmVJNXJxMS9DWUd1VlkK",
      "endpoints": [
        "https://github.com/nielsgl/resetping/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
